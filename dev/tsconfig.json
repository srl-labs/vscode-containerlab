{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "preserveSymlinks": false,
    "paths": {
      "@srl-labs/clab-ui": ["../node_modules/@srl-labs/clab-ui/src/index.ts"],
      "@srl-labs/clab-ui/*": ["../node_modules/@srl-labs/clab-ui/src/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx"
  ]
}
